# Point these at the deployed Creative Monk API to make the site dynamic
# and enable the admin. When unset, the site renders from bundled static
# content (so it always works) and the admin shows a "configure API" notice.

# Server-side data fetching for public pages (server components):
API_URL=

# Client-side fetching (admin dashboard + contact/newsletter forms).
# MUST be prefixed NEXT_PUBLIC_ to be exposed to the browser:
NEXT_PUBLIC_API_URL=

# Optional: ISR revalidation window in seconds for CMS reads (default 60)
# CMS_REVALIDATE=60

# ── Analytics ──
# GA4 measurement ID. Loading gtag.js also satisfies Google Search Console's
# "Google Analytics" ownership verification. Defaults to the production ID.
NEXT_PUBLIC_GA_ID=G-1XX3SG68HR

# Optional Google Tag Manager container (e.g. GTM-XXXXXXX). Search Console
# currently has GTM on file as the verification method.
# NEXT_PUBLIC_GTM_ID=

# Optional: the token from Search Console's "HTML tag" method, as a backup
# verification route (just the content value, not the whole meta tag).
# NEXT_PUBLIC_GSC_VERIFICATION=

# ── Cloudflare Turnstile (captcha) ──
# Public site key from dash.cloudflare.com → Turnstile. When unset, forms
# render without a captcha so nothing breaks before the keys are configured.
# The matching TURNSTILE_SECRET_KEY goes in the backend env.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# ── Careers application form ──
# Optional fallbacks if you'd rather not set the embed in the CMS.
# Either one REPLACES the built-in application form on /careers/apply.
# NEXT_PUBLIC_CAREERS_EMBED_URL=
# NEXT_PUBLIC_CAREERS_EMBED_CODE=
